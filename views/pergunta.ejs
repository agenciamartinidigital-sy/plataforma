<%- include("partials/header.ejs") %>
<body>
  <%- include("partials/navbar.ejs") %>

  <div class="container">
    <h1><%= pergunta.titulo %></h1>
    <p><%= pergunta.descricao %></p>
    <hr />
    <form method="POST" action="/responder">
      <h3>Responda com educação</h3>
      <label for="">Resposta: </label>
      <textarea
        name="corpo"
        id=""
        placeholder="Digite sau resposta"
        class="form-control"
      ></textarea>
      <input type="hidden" name="pergunta" value="<%= pergunta.id %>">
      <button type="submit" class="btn btn-primary mt-2">Responder</button>
    </form>
    <hr>
    <h3>Respostas</h3>
    <hr>
    <% respostas.forEach(resposta => { %>
      <div class="card mt-2">
        <div class="card-body">
          <%= resposta.corpo %>
        </div>
      </div>
    <% }) %>
  </div>
  <a href="/" class="btn btn-primary m-3">Volar</a>
</body>
<%- include("partials/footer.ejs") %>
